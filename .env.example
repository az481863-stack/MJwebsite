# ── Supabase / PostgreSQL(Prisma)──────────────────────────────
# 取得方式:Supabase 專案 → Project Settings → Database → Connection string
#
# DATABASE_URL:應用程式執行期用,走 Transaction pooler(port 6543),須帶 ?pgbouncer=true
# DIRECT_URL  :prisma migrate / db push 用,走直連(port 5432),不可走 pooler
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Auth / Storage(前端與伺服器端用)─────────────────
# 取得方式:Supabase 專案 → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
# 僅伺服器端使用,切勿暴露到前端
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ── 站台網址(組邀請連結、OAuth redirect 用)──────────────────
# 開發:http://localhost:3000;正式:Vercel 部署網址(如 https://mjwebsite.vercel.app)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── 郵件(Resend)─────────────────────────────────────────────
# 取得方式:resend.com → API Keys。未設定時開發期會把邀請連結印到 console。
RESEND_API_KEY="<resend-api-key>"
# 寄件位址;正式須為 Resend 已驗證網域。未設定預設 onboarding@resend.dev(僅供測試)
EMAIL_FROM="光電物理實驗室 <onboarding@resend.dev>"

# ── 聯絡表單(階段四)收件信箱 ─────────────────────────────────
# 聯絡頁表單三種分類的訊息都會寄到這些信箱;可多個,以逗號分隔。
CONTACT_RECIPIENTS="prof@example.edu.tw, ta@example.edu.tw"

# ── 首位最高權限者設定密語 ─────────────────────────────────────
# /setup 頁建立第一位最高權限者時需輸入此密語(防止被路過者搶先註冊)。
# 建立完成後 /setup 自動失效。請設一組夠長的隨機字串。
SETUP_SECRET="<set-a-long-random-string>"

# ── 階段五:儀器對帳排程密語 ───────────────────────────────────
# 保護 /api/cron(儀器自動簽到/逾時對帳)。GitHub Actions 以 Bearer 此值呼叫。
# 須與 GitHub repo secret CRON_SECRET 相同。請設一組夠長的隨機字串。
CRON_SECRET="<set-a-long-random-string>"
