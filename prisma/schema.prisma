// 光電物理實驗室網站 — Prisma schema
// 單一事實來源見 CLAUDE.md。本檔對應 B(角色/權限)、C(會員系統)、D(共用系統欄位)。
//
// 階段零僅奠定「會員核心 + 穩定 ID + 共用欄位」地基,這是 D/E 所述
// 所有現在與未來模組關聯引用的根。其餘區塊(內容 CMS、儀器)於對應階段再擴充。
//
// 驗證(密碼、Google 登入)由 Supabase Auth(auth.users)負責,本表不存密碼雜湊;
// Member.authUserId 對應 Supabase auth.users.id。

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  // 改用 client engine(Wasm query compiler)+ driver adapter,完全不依賴
  // 平台專屬的 Rust query engine(.so.node)。這解決了自訂 output + Next 16
  // (Turbopack)在 Vercel 上「engine not found for rhel-openssl-3.0.x」的問題:
  // 沒有原生二進位檔需要被打包進 serverless function,自然不會找不到。
  // 連線改由 @prisma/adapter-pg 經 node-postgres 建立(見 src/lib/prisma.ts)。
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  // 應用程式執行期走 Supabase 連線池(pooler, port 6543)
  url       = env("DATABASE_URL")
  // 遷移/introspection 走直連(port 5432);Supabase 連線池不支援 DDL
  directUrl = env("DIRECT_URL")
}

// ── B. 三層全站角色(權限往上累加) ──────────────────────────────
enum Role {
  STUDENT // 第三層:學生(投稿者)
  ADMIN // 第二層:管理員(助教)
  SUPERADMIN // 第一層:最高權限者(教授/大助教)
}

// ── C-2. 會員狀態 ───────────────────────────────────────────────
enum MemberStatus {
  PENDING // 未啟用:已建立、未設密碼,不能登入
  ACTIVE // 已啟用:正常使用
  DISABLED // 已停用:停止登入但保留歷史資料(取代「刪除」)
}

// ── 會員核心(C-4 欄位;D 共用系統欄位) ────────────────────────
// 每個會員擁有穩定不變的主鍵 ID,供現在與未來所有模組關聯引用。
model Member {
  id String @id @default(uuid())

  // 對應 Supabase auth.users.id;未啟用前為 null
  authUserId String? @unique @map("auth_user_id")

  loginEmail String       @unique @map("login_email") // 主要識別
  role       Role         @default(STUDENT)
  status     MemberStatus @default(PENDING)

  // C-4 一對多:常用 email(資料層為 1 ─ N,非單欄)
  contactEmails ContactEmail[]

  // C-1 邀請:一位會員可由一筆邀請產生(最高權限者由手動升級,可無邀請)
  invitations Invitation[]

  // 階段五:儀器級負責人(B-2)與預約紀錄
  managedInstruments InstrumentManager[] @relation("MemberManagedInstruments")
  reservations       Reservation[]       @relation("MemberReservations")

  // ── D. 共用系統欄位 ──
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") // 建立者會員 ID
  updatedBy String?   @map("updated_by") // 最後更新者會員 ID
  deletedAt DateTime? @map("deleted_at") // 軟刪除標記(非 NULL 即視為已刪除)
  deletedBy String?   @map("deleted_by") // 執行刪除者會員 ID

  @@index([status])
  @@index([deletedAt])
  @@map("members")
}

// C-4 常用 email(會員 1 ─ N email)
model ContactEmail {
  id       String @id @default(uuid())
  email    String
  memberId String @map("member_id")
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([memberId, email])
  @@map("contact_emails")
}

// ── C-1 / C-3. 邀請會員制 ───────────────────────────────────────
// 新增邀請即建立一筆未啟用 Member;此表存放邀請連結 token 與時效。
model Invitation {
  id String @id @default(uuid())

  email      String // 受邀人 email
  role       Role      @default(STUDENT) // 最高權限者可指定;管理員固定 STUDENT
  tokenHash  String    @unique @map("token_hash") // 隨機 token 之雜湊(勿存明碼)
  expiresAt  DateTime  @map("expires_at") // 建議 7 天
  acceptedAt DateTime? @map("accepted_at") // 啟用後作廢,不可重用
  revokedAt  DateTime? @map("revoked_at") // 重寄邀請時舊連結失效

  // 啟用後關聯到實際建立的會員
  memberId String? @map("member_id")
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") // 發出邀請者(最高權限者/管理員)

  @@index([email])
  @@map("invitations")
}

// ════════════════════════════════════════════════════════════════
// 階段三:內容後台 CMS(附錄 G)
// 共通:每種內容含 D 共用系統欄位 + 發布狀態;前台只顯示
//       status=PUBLISHED 且 deletedAt=null 者。created_by 等存會員 ID(非 FK)。
// ════════════════════════════════════════════════════════════════

// 內容發布狀態(草稿/審核流程):學生建 DRAFT,管理員以上 PUBLISHED。
enum ContentStatus {
  DRAFT
  PUBLISHED
}

// G-1 動態佈告欄分類
enum DashboardCategory {
  ACADEMIC // 學術快報
  LAB_LIFE // 實驗室日常
  HONOR // 榮譽榜
}

// G-3 現役成員身份階層
enum TeamTier {
  POSTDOC // 博後
  PHD // 博士生
  MASTER // 碩士生
  UNDERGRAD // 專題生
}

// G-5 職缺招募狀態(與內容 status 無關)
enum RecruitStatus {
  OPEN // 開放
  FULL // 額滿
}

// G-8 產學與專利分類
enum IndustryCategory {
  PATENT // 已獲證專利
  LICENSABLE // 可授權技術
  COLLABORATION // 企業合作/技轉實績
}

// G-1 動態佈告欄(Quantum Dashboard)
model DashboardPost {
  id            String            @id @default(uuid())
  category      DashboardCategory
  title         String
  body          String
  imageUrl      String?           @map("image_url")
  linkUrl       String?           @map("link_url")
  linkText      String?           @map("link_text")
  publishedDate DateTime          @map("published_date")
  status        ContentStatus     @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("dashboard_posts")
}

// G-2 Publications(階段六可 AI 填)
model Publication {
  id        String        @id @default(uuid())
  authors   String
  title     String
  venue     String // 期刊名稱
  year      Int
  doiUrl    String?       @map("doi_url")
  highlight Boolean       @default(false) // 精選:前台加粗放大
  status    ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("publications")
}

// G-3 現役成員(顯示用,與 auth Member 無關)
model TeamMember {
  id            String        @id @default(uuid())
  name          String
  tier          TeamTier
  photoUrl      String?       @map("photo_url")
  researchTopic String?       @map("research_topic")
  sortOrder     Int           @default(0) @map("sort_order")
  status        ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("team_members")
}

// G-4 校友去向
model Alumnus {
  id          String        @id @default(uuid())
  name        String
  gradYear    Int           @map("grad_year")
  destination String
  sortOrder   Int           @default(0) @map("sort_order")
  status      ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("alumni")
}

// G-5 學術能階職缺表
model JobOpening {
  id            String        @id @default(uuid())
  title         String
  sortOrder     Int           @default(0) @map("sort_order") // 層級排序
  recruitStatus RecruitStatus @default(OPEN) @map("recruit_status")
  slots         Int? // 名額(選)
  description   String
  status        ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("job_openings")
}

// G-6 Science Blog(中英雙版;內文用 Tiptap JSON;階段六可 AI 填)
model BlogPost {
  id            String        @id @default(uuid())
  titleZh       String        @map("title_zh")
  titleEn       String        @map("title_en")
  summary       String?
  bodyZh        Json          @map("body_zh") // Tiptap JSON
  bodyEn        Json          @map("body_en") // Tiptap JSON
  coverUrl      String?       @map("cover_url")
  publishedDate DateTime      @map("published_date")
  status        ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("blog_posts")
}

// G-7 課程紀錄
model Course {
  id          String        @id @default(uuid())
  name        String
  outline     String
  handoutUrl  String?       @map("handout_url")
  sortOrder   Int           @default(0) @map("sort_order")
  status      ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("courses")
}

// G-8 產學與專利
model IndustryItem {
  id          String           @id @default(uuid())
  category    IndustryCategory
  title       String
  description String
  sortOrder   Int              @default(0) @map("sort_order")
  status      ContentStatus    @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("industry_items")
}

// G-9 給高中生的話(單篇長文;通常只有一筆有效)
model HighSchoolMessage {
  id      String        @id @default(uuid())
  content String
  status  ContentStatus @default(DRAFT)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, deletedAt])
  @@map("highschool_messages")
}

// 全站設定(單列):頁面顯示/隱藏開關 + 全站參數。
// 以固定 id="singleton" 確保只有一列。
model SiteSettings {
  id String @id @default("singleton")

  // 頁面顯示開關(前台與導覽)
  showResearch    Boolean @default(true) @map("show_research")
  showTeam        Boolean @default(true) @map("show_team")
  showInstruments Boolean @default(false) @map("show_instruments") // 階段五前預設隱藏
  showBlog        Boolean @default(true) @map("show_blog")
  showContact     Boolean @default(true) @map("show_contact")
  showIndustry    Boolean @default(true) @map("show_industry") // G-8 產學與專利
  showHighschool  Boolean @default(true) @map("show_highschool") // G-9 給高中生的話

  // 全站參數
  instrumentMaxHours Int @default(24) @map("instrument_max_hours") // 階段五:預約總時數上限

  // 前台 Dark Optics 主題的重點色(存色票 key,見 src/lib/accent.ts)
  siteAccent String @default("cyan") @map("site_accent")

  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("site_settings")
}

// ════════════════════════════════════════════════════════════════
// 階段五:儀器預約管理系統(附錄 H)
// 同一份儀器資料、兩種視角(管理頁 / 預約頁)。
// 停權與額度為衍生計算(見 src/lib/instruments.ts),不另設表。
// ════════════════════════════════════════════════════════════════

// 附錄 H 機台目前狀態(負責人/管理員手動調整,與簽退脫鉤)
enum InstrumentStatus {
  NORMAL // 🟢 正常運行
  MAINTENANCE // 🟡 維護中
}

// 預約紀錄狀態(附錄 H:已預約/已取消/使用中·未簽退/已簽退/逾時)
enum ReservationStatus {
  BOOKED // 已預約
  CANCELLED // 已取消(時段開始前提前取消)
  IN_USE // 使用中·未簽退(時段一到自動簽到,產生簽退義務)
  CHECKED_OUT // 已簽退
  OVERDUE // 逾時未簽退(逾使用結束 3 天;本人不再開放簽退)
}

// 簽退機況回報(🟢正常 / 🟡異音不穩 / 🔴故障)
enum ConditionReport {
  NORMAL // 🟢 正常
  UNSTABLE // 🟡 異音不穩
  BROKEN // 🔴 故障
}

// 儀器(附錄 H)
model Instrument {
  id        String           @id @default(uuid())
  name      String
  purpose   String // 用途說明(長文)
  photoUrl  String?          @map("photo_url")
  status    InstrumentStatus @default(NORMAL) // 目前狀態(手動調整)
  sortOrder Int              @default(0) @map("sort_order")

  managers     InstrumentManager[]
  reservations Reservation[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([deletedAt])
  @@map("instruments")
}

// B-2 儀器層級負責人(會員 ─ 負責 ─ 儀器,多對多)
model InstrumentManager {
  id           String     @id @default(uuid())
  instrumentId String     @map("instrument_id")
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  memberId     String     @map("member_id")
  member       Member     @relation("MemberManagedInstruments", fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@unique([instrumentId, memberId])
  @@index([memberId])
  @@map("instrument_managers")
}

// 預約紀錄
model Reservation {
  id           String     @id @default(uuid())
  instrumentId String     @map("instrument_id")
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  memberId     String     @map("member_id")
  member       Member     @relation("MemberReservations", fields: [memberId], references: [id], onDelete: Cascade)

  startAt     DateTime          @map("start_at") // 整點
  endAt       DateTime          @map("end_at") // 整點
  status      ReservationStatus @default(BOOKED)
  cancelledAt DateTime?         @map("cancelled_at")
  checkedInAt DateTime?         @map("checked_in_at") // 自動簽到時間

  checkout Checkout?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([instrumentId, startAt])
  @@index([status])
  @@index([memberId, status])
  @@map("reservations")
}

// 簽退/異常紀錄
model Checkout {
  id            String          @id @default(uuid())
  reservationId String          @unique @map("reservation_id")
  reservation   Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  hours         Int // 確認時數
  condition     ConditionReport // 機況回報(強制)
  anomalyNote   String?         @map("anomaly_note") // 異常描述(選)
  byMemberId    String          @map("by_member_id") // 簽退執行者
  isProxy       Boolean         @default(false) @map("is_proxy") // 代簽

  createdAt DateTime @default(now()) @map("created_at")

  @@map("checkouts")
}
